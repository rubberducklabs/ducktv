# Copy to .env and adjust for your Unraid host:
#   cp .env.example .env
#
# Generate SECRET_KEY_BASE with:
#   openssl rand -base64 48

# Phoenix
PORT=4000
PHX_HOST=192.168.1.50
PHX_SCHEME=http
# Public URL port for share links (not the container bind port).
# Direct LAN (:4000): leave unset or set 4000.
# Reverse proxy: PHX_PORT=80 (http) or omit with PHX_SCHEME=https (uses 443).
# PHX_PORT=80
SECRET_KEY_BASE=replace-me-with-output-of-mix-phx-gen-secret

# UI shared-secret auth (cookie session, Argon2-verified)
AUTH_KEY=replace-me-with-a-long-random-password

# TVHeadend connection
TVHEADEND_URL=http://10.0.1.10:9981
TVHEADEND_USER=admin
TVHEADEND_PASSWORD=admin
TVHEADEND_AUTH=basic

# Stream encoding / HLS
HLS_ROOT=/data/hls
FFMPEG_PATH=ffmpeg
FFMPEG_PRESET=veryfast
FFMPEG_CRF=20
FFMPEG_MAXRATE=6M
FFMPEG_BUFSIZE=12M
FFMPEG_AUDIO_BITRATE=192k
STREAM_IDLE_MS=30000
STREAM_STARTUP_TIMEOUT_MS=45000
STREAM_COPY_STARTUP_TIMEOUT_MS=120000
STREAM_MAX_CONCURRENT=8
HOT_CHANNELS=1
STREAM_COPY=auto

# Recording web-version transcodes (mount a host folder here for persistence)
TRANSCODE_ROOT=/data/transcodes
TRANSCODE_THREADS=4
TRANSCODE_PRESET=veryfast
TRANSCODE_CRF=23
TRANSCODE_AUDIO_BITRATE=160k
